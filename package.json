{
  "name": "canvakilla",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "canvakilla": "./bin/canvakilla.mjs"
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "cli": "node ./bin/canvakilla.mjs",
    "dev": "next dev",
